# BSD (Bzzoiro Sports Data) — utilisé uniquement côté serveur
# https://sports.bzzoiro.com/docs/
BSD_API_KEY=your_bsd_token

# Optionnel : si tu connais déjà l'ID de la ligue WC2026, le mettre ici évite
# l'appel de découverte. Sinon /api/leagues/ est appelé une fois et caché 24h.
BSD_WORLD_CUP_LEAGUE_ID=
BSD_WORLD_CUP_SEASON_ID=

# Supabase — clé publishable (anon) côté client
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# Supabase — clé service_role côté serveur uniquement (écriture matches)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxx

# Secret pour les endpoints /api/cron/* (Vercel Cron envoie Authorization: Bearer ...)
CRON_SECRET=change_me
